ss=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;<span class=\"w\"> </span>-b<span class=\"w\"> </span><span class=\"s2\">&quot;session=abc123; role=FUZZ&quot;</span><span class=\"w\"> </span>--sc<span class=\"w\"> </span><span class=\"m\">200</span><span class=\"w\"> </span>&lt;url&gt;/admin\n\n<span class=\"c1\"># Cookie + POST</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-b<span class=\"w\"> </span><span class=\"s2\">&quot;session=abc123&quot;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-d<span class=\"w\"> </span><span class=\"s2\">&quot;action=FUZZ&quot;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>--hc<span class=\"w\"> </span><span class=\"m\">403</span><span class=\"w\"> </span>&lt;url&gt;/admin/action\n</code></pre></div>\n<h2 id=\"encoders\">Encoders</h2>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># URL encode the payload</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:urlencode<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># Base64 encode</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:base64<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># HTML encode</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:html<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># MD5 hash</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:md5<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># Double URL encode (bypass WAF)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:urlencode:urlencode<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># Multiple encoders (try all against each word)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>&lt;wordlist&gt;:urlencode,base64<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># List available encoders</span>\nwfuzz<span class=\"w\"> </span>-e<span class=\"w\"> </span>encoders\n</code></pre></div>\n<h2 id=\"iterators\">Iterators</h2>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># Default: zip (pairs elements 1:1)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list1.txt<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list2.txt<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ/FUZ2Z\n\n<span class=\"c1\"># Product (all combinations)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list1.txt<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list2.txt<span class=\"w\"> </span>-m<span class=\"w\"> </span>product<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ/FUZ2Z\n\n<span class=\"c1\"># Chain (concatenate wordlists)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list1.txt<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,list2.txt<span class=\"w\"> </span>-m<span class=\"w\"> </span>chain<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># List iterator</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>list,<span class=\"s2\">&quot;admin-user-test-guest&quot;</span><span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n</code></pre></div>\n<h2 id=\"common-attack-patterns\">Common Attack Patterns</h2>\n<h3 id=\"auth-bypass\">Auth Bypass</h3>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># SQL injection in login</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Fuzzing/SQLi/Generic-SQLi.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-d<span class=\"w\"> </span><span class=\"s2\">&quot;username=FUZZ&amp;password=test&quot;</span><span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">200</span><span class=\"w\"> </span>&lt;url&gt;/login\n\n<span class=\"c1\"># NoSQL injection</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Fuzzing/Databases/NoSQL.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-H<span class=\"w\"> </span><span class=\"s2\">&quot;Content-Type: application/json&quot;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-d<span class=\"w\"> </span><span class=\"s1\">&#39;{&quot;username&quot;:{&quot;$gt&quot;:&quot;&quot;},&quot;password&quot;:{&quot;$gt&quot;:&quot;&quot;}}&#39;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>--sc<span class=\"w\"> </span><span class=\"m\">200</span><span class=\"w\"> </span>&lt;url&gt;/api/login\n\n<span class=\"c1\"># Admin path bypass</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Fuzzing/LFI/LFI-Jhaddix.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span>&lt;url&gt;/FUZZ\n\n<span class=\"c1\"># HTTP verb bypass for 403</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>list,<span class=\"s2\">&quot;GET-POST-PUT-PATCH-DELETE-OPTIONS-HEAD-TRACE&quot;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-X<span class=\"w\"> </span>FUZZ<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">403</span><span class=\"w\"> </span>&lt;url&gt;/admin\n</code></pre></div>\n<h3 id=\"parameter-discovery\">Parameter Discovery</h3>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># Hidden GET parameter discovery</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Discovery/Web-Content/burp-parameter-names.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>--hh<span class=\"w\"> </span><span class=\"m\">1234</span><span class=\"w\"> </span><span class=\"s2\">&quot;&lt;url&gt;?FUZZ=test&quot;</span>\n\n<span class=\"c1\"># Hidden POST parameter discovery</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Discovery/Web-Content/burp-parameter-names.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-d<span class=\"w\"> </span><span class=\"s2\">&quot;FUZZ=test&quot;</span><span class=\"w\"> </span>--hh<span class=\"w\"> </span><span class=\"m\">1234</span><span class=\"w\"> </span>&lt;url&gt;/submit\n\n<span class=\"c1\"># IDOR parameter fuzzing</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>range,1-1000<span class=\"w\"> </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span><span class=\"s2\">&quot;&lt;url&gt;/user?id=FUZZ&quot;</span>\n</code></pre></div>\n<h3 id=\"vhost-subdomain\">VHOST / Subdomain</h3>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># VHost fuzzing</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-H<span class=\"w\"> </span><span class=\"s2\">&quot;Host: FUZZ.&lt;domain&gt;&quot;</span><span class=\"w\"> </span>--hh<span class=\"w\"> </span><span class=\"m\">1234</span><span class=\"w\"> </span>http://&lt;ip&gt;/\n\n<span class=\"c1\"># Subdomain + path</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-z<span class=\"w\"> </span>file,/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt<span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>-z<span class=\"w\"> </span>file,&lt;wordlist&gt;<span class=\"w\"> </span>-H<span class=\"w\"> </span><span class=\"s2\">&quot;Host: FUZZ.&lt;domain&gt;&quot;</span><span class=\"w\"> </span><span class=\"se\">\\</span>\n<span class=\"w\">  </span>--hc<span class=\"w\"> </span><span class=\"m\">404</span><span class=\"w\"> </span><span class=\"s2\">&quot;http://&lt;ip&gt;/FUZ2Z&quot;</span>\n</code></pre></div>\n<h3 id=\"credential-brute-force\">Credential Brute Force</h3>\n<div class=\"highlight\"><pre><span></span><code><span class=\"c1\"># Password spray (one password, many users)</span>\nwfuzz<span class=\"w\"> </span>-c<span class=\"w\"> </span>-w<span class=\"w\"> </span>/usr/share/sec