{"title": "qpdf", "source": "gtfobins", "source_label": "GTFOBins", "path": "qpdf", "html": "<h1>qpdf</h1>\n<h2>File Read</h2>\n<pre><code class=\"language-bash\">qpdf --empty --add-attachment /path/to/input-file --key=x -- /path/to/output-file\nqpdf --show-attachment=x /path/to/output-file</code></pre>", "excerpt": "qpdf File Read qpdf --empty --add-attachment /path/to/input-file --key=x -- /path/to/output-file qpdf --show-attachment=x /path/to/output-file", "tags": ["func:file-read", "ctx:sudo", "ctx:suid", "ctx:unprivileged"]}