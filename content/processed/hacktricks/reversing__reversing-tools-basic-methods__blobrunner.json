\">);</span>\n<span class=\"w\">    </span><span class=\"n\">printf</span><span class=\"p\">(</span><span class=\"s\">&quot; [*] Copying input data...</span><span class=\"se\">\\n</span><span class=\"s\">&quot;</span><span class=\"p\">);</span>\n\n<span class=\"w\">    </span><span class=\"n\">CopyMemory</span><span class=\"p\">(</span><span class=\"n\">lpvBase</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">buffer</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">fileLen</span><span class=\"p\">);</span>\n<span class=\"w\">    </span><span class=\"k\">return</span><span class=\"w\"> </span><span class=\"n\">lpvBase</span><span class=\"p\">;</span>\n<span class=\"p\">}</span>\n\n<span class=\"kt\">void</span><span class=\"w\"> </span><span class=\"nf\">execute</span><span class=\"p\">(</span><span class=\"n\">LPVOID</span><span class=\"w\"> </span><span class=\"n\">base</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"kt\">int</span><span class=\"w\"> </span><span class=\"n\">offset</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"kt\">bool</span><span class=\"w\"> </span><span class=\"n\">nopause</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"kt\">bool</span><span class=\"w\"> </span><span class=\"n\">jit</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"kt\">bool</span><span class=\"w\"> </span><span class=\"n\">debug</span><span class=\"p\">)</span>\n<span class=\"p\">{</span>\n<span class=\"w\">    </span><span class=\"n\">LPVOID</span><span class=\"w\"> </span><span class=\"n\">shell_entry</span><span class=\"p\">;</span>\n\n<span class=\"cp\">#ifdef _WIN64</span>\n<span class=\"w\">    </span><span class=\"n\">DWORD</span><span class=\"w\">   </span><span class=\"n\">thread_id</span><span class=\"p\">;</span>\n<span class=\"w\">    </span><span class=\"n\">HANDLE</span><span class=\"w\">  </span><span class=\"n\">th